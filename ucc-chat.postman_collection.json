{
	"info": {
		"_postman_id": "ucc-chat-api-collection",
		"name": "UCC Chat API",
		"description": "Collection for UCC Chat application including Guest and Agent endpoints.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login (Get Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set(\"auth_token\", jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"agent@example.com\",\n    \"password\": \"password\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"login"
							]
						}
					}
				}
			]
		},
		{
			"name": "Guest Chat",
			"item": [
				{
					"name": "Start Chat",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.session_id) {",
									"    pm.collectionVariables.set(\"session_id\", jsonData.session_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"guest@example.com\",\n    \"name\": \"John Doe\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/chat/start",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"chat",
								"start"
							]
						}
					}
				},
				{
					"name": "Get Messages",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/chat/{{session_id}}/messages",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"chat",
								"{{session_id}}",
								"messages"
							]
						}
					}
				},
				{
					"name": "Send Message",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"content\": \"Hello, I need help!\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/chat/{{session_id}}/message",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"chat",
								"{{session_id}}",
								"message"
							]
						}
					}
				},
				{
					"name": "Escalate to Agent",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/chat/{{session_id}}/escalate",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"chat",
								"{{session_id}}",
								"escalate"
							]
						}
					}
				}
			]
		},
		{
			"name": "Agent Chat",
			"item": [
				{
					"name": "Dashboard (Active Chats)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/agent/chats",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"agent",
								"chats"
							]
						}
					}
				},
				{
					"name": "Closed Chats",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/agent/chats/closed",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"agent",
								"chats",
								"closed"
							]
						}
					}
				},
				{
					"name": "Get Chat Messages",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/agent/chats/{{chat_id}}/messages",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"agent",
								"chats",
								"{{chat_id}}",
								"messages"
							]
						}
					}
				},
				{
					"name": "Send Message (as Agent)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"content\": \"Hello, how can I assist you today?\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/agent/chats/{{chat_id}}/message",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"agent",
								"chats",
								"{{chat_id}}",
								"message"
							]
						}
					}
				},
				{
					"name": "Assign Chat to Self",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/agent/chats/{{chat_id}}/assign",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"agent",
								"chats",
								"{{chat_id}}",
								"assign"
							]
						}
					}
				},
				{
					"name": "Close Chat",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/agent/chats/{{chat_id}}/close",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"agent",
								"chats",
								"{{chat_id}}",
								"close"
							]
						}
					}
				}
			],
			"auth": {
				"type": "bearer",
				"bearer": [
					{
						"key": "token",
						"value": "{{auth_token}}",
						"type": "string"
					}
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://ucc-chat.local",
			"type": "string"
		},
		{
			"key": "auth_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "session_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "chat_id",
			"value": "1",
			"type": "string"
		}
	]
}
